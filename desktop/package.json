{
  "name": "lexiflow-desktop",
  "version": "1.0.0",
  "description": "LexiFlow Desktop App — Local Discovery-Vault Sync & PII/PHI Redaction",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "ELECTRON_DEV=true electron .",
    "build": "electron-builder build"
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "chokidar": "^3.6.0",
    "crypto-js": "^4.2.0",
    "node-fetch": "^2.7.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0"
  },
  "build": {
    "appId": "co.lexiflow.desktop",
    "productName": "LexiFlow Desktop",
    "files": [
      "main.js",
      "preload.js",
      "sync-engine.js",
      "redact-utils.js",
      "renderer/**/*"
    ],
    "directories": {
      "output": "dist"
    }
  }
}