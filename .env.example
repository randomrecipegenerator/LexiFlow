# LexiFlow Configuration Example
# Copy this file to .env and fill in your actual keys

# AI API Configuration (OpenAI or Groq compatible)
AI_API_KEY=your_api_key_here
AI_BASE_URL=https://api.groq.com/openai/v1
AI_MODEL=llama-3.1-8b-instant

# Optional: Direct OpenAI Configuration
# OPENAI_API_KEY=your_openai_key

# CRM Integration Placeholders
CLIO_API_KEY=placeholder_clio_token
MYCASE_API_KEY=placeholder_mycase_token
FILEVINE_API_KEY=placeholder_filevine_token

# URL Configuration
FRONTEND_URL=http://localhost:8000
BACKEND_URL=http://localhost:8000
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Database Configuration (Defaults to local SQLite)
# DATABASE_URL=sqlite:///./lexiflow.db
