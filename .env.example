# LexiFlow Configuration Example
# Copy this file to .env and fill in your actual keys

# 1. AI API Configuration
# Use Groq (Default)
AI_API_KEY=your_groq_api_key_here
AI_BASE_URL=https://api.groq.com/openai/v1
AI_MODEL=llama-3.1-70b-versatile

# OR use OpenAI
# OPENAI_API_KEY=your_openai_key_here
# AI_BASE_URL=https://api.openai.com/v1
# AI_MODEL=gpt-4o

# 2. Database Configuration
# Local SQLite (Development only)
DATABASE_URL=sqlite:///./lexiflow.db

# Turso (Recommended for Production)
# DATABASE_URL=libsql://your-db-name.turso.io
# DATABASE_AUTH_TOKEN=your-auth-token-here

# 3. Integration Secrets
POSTMARK_SERVER_TOKEN=your_postmark_token_here
VAPI_API_KEY=your_vapi_key_here
ESIGN_API_KEY=your_dropbox_sign_key_here

# 4. URL & Security
FRONTEND_URL=http://localhost:8000
BACKEND_URL=http://localhost:8000
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# 5. CRM Defaults (Optional, usually configured per-firm in dashboard)
# CLIO_CLIENT_ID=...
# CLIO_CLIENT_SECRET=...

# 6. Stripe (Billing & Payments)
# After Stripe Connect onboarding (scheduled Tue, June 23), replace with live keys.
# Test keys (starts with sk_test_ / pk_test_) for development; live keys for production.
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
# Generated from Stripe Dashboard > Developers > Webhooks after deploying webhook endpoint
# STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret_here
# Stripe Price IDs — created via Stripe Dashboard or API after product setup
# STRIPE_PRICE_STANDARD=price_standard_monthly
# STRIPE_PRICE_PROFESSIONAL=price_professional_monthly
# STRIPE_PRICE_ENTERPRISE=price_enterprise_monthly
