{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "functions": {
    "api/index.py": {
      "runtime": "vercel-python@0.0.1"
    }
  },
  "rewrites": [
    {
      "source": "/veritas/:path*",
      "destination": "/veritas/index.html"
    },
    {
      "source": "/__engine/events",
      "destination": "/api/index.py"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/blog/articles.json",
      "destination": "/blog/articles.json"
    },
    {
      "source": "/blog/([^/.]+)",
      "destination": "/blog/$1.html"
    },
    {
      "source": "/case-studies/([^/.]+)",
      "destination": "/case-studies/$1.html"
    }
  ]
}
