{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "memory": 512,
        "maxDuration": 30
      }
    },
    {
      "src": "*.html",
      "use": "@vercel/static"
    },
    {
      "src": "assets/**/*",
      "use": "@vercel/static"
    },
    {
      "src": "branding/**/*",
      "use": "@vercel/static"
    },
    {
      "src": "blog/**/*",
      "use": "@vercel/static"
    },
    {
      "src": "case-studies/**/*",
      "use": "@vercel/static"
    },
    {
      "src": "admin/**/*",
      "use": "@vercel/static"
    },
    {
      "src": "hardened-suite/**/*",
      "use": "@vercel/static"
    },
    {
      "src": "practice-areas/**/*",
      "use": "@vercel/static"
    },
    {
      "src": "resources/**/*",
      "use": "@vercel/static"
    },
    {
      "src": "veritas/**/*",
      "use": "@vercel/static"
    },
    {
      "src": "desktop/**/*",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    {
      "source": "/veritas/:path*",
      "destination": "/veritas/index.html"
    },
    {
      "source": "/admin/:path*",
      "destination": "/admin/index.html"
    },
    {
      "source": "/hardened-suite/:path*",
      "destination": "/hardened-suite/index.html"
    },
    {
      "source": "/practice-areas/:path*",
      "destination": "/practice-areas/index.html"
    },
    {
      "source": "/desktop/:path*",
      "destination": "/desktop/index.html"
    },
    {
      "source": "/__engine/events",
      "destination": "/api/index.py"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/blog/articles.json",
      "destination": "/blog/articles.json"
    },
    {
      "source": "/blog/([^/.]+)",
      "destination": "/blog/$1.html"
    },
    {
      "source": "/case-studies/([^/.]+)",
      "destination": "/case-studies/$1.html"
    },
    {
      "source": "/practice-areas/medical-malpractice/([^/.]+)",
      "destination": "/practice-areas/medical-malpractice/$1.html"
    }
  ]
}