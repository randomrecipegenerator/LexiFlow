{
  "version": 2,
  "cleanUrls": true,
  "builds": [
    {
      "src": "**/*.html",
      "use": "@vercel/static"
    },
    {
      "src": "**/*.{xml,txt,png,svg,ico,js,css,json}",
      "use": "@vercel/static"
    },
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "rewrites": [
    {
      "source": "/__engine/events",
      "destination": "/api/index.py"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/demo",
      "destination": "/demo.html"
    },
    {
      "source": "/dashboard",
      "destination": "/dashboard.html"
    },
    {
      "source": "/veritas/assets/(.*)",
      "destination": "/veritas-deposition/frontend/dist/assets/$1"
    },
    {
      "source": "/veritas/(.*)",
      "destination": "/veritas-deposition/frontend/dist/index.html"
    },
    {
      "source": "/veritas",
      "destination": "/veritas-deposition/frontend/dist/index.html"
    }
  ]
}
