{
  "version": 2,
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/__engine/events",
      "destination": "/api/index.py"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/demo",
      "destination": "/demo.html"
    },
    {
      "source": "/dashboard",
      "destination": "/dashboard.html"
    },
    {
      "source": "/veritas",
      "destination": "/veritas-deposition/frontend/dist/index.html"
    }
  ]
}
