{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "builds": [
    {
      "src": "**/*.html",
      "use": "@vercel/static"
    },
    {
      "src": "**/*.{xml,txt,png,svg,ico,js,css,json,pdf}",
      "use": "@vercel/static"
    },
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "functions": {
    "api/index.py": {
      "memory": 512,
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/veritas/:path*",
      "destination": "/veritas/index.html"
    },
    {
      "source": "/__engine/events",
      "destination": "/api/index.py"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/blog/articles.json",
      "destination": "/blog/articles.json"
    },
    {
      "source": "/blog/([^/.]+)",
      "destination": "/blog/$1.html"
    },
    {
      "source": "/case-studies/([^/.]+)",
      "destination": "/case-studies/$1.html"
    }
  ]
}
