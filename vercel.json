{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "builds": [
    {
      "src": "**/*.html",
      "use": "@vercel/static"
    },
    {
      "src": "**/*.{xml,txt,png,svg,ico,js,css,json,pdf}",
      "use": "@vercel/static"
    },
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "rewrites": [
    {
      "source": "/__engine/events",
      "destination": "/api/index.py"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/blog/articles.json",
      "destination": "/blog/articles.json"
    },
    {
      "source": "/blog/([^/.]+)",
      "destination": "/blog/$1.html"
    },
    {
      "source": "/veritas/assets/(.*)",
      "destination": "/veritas/assets/$1"
    },
    {
      "source": "/veritas/(.*)",
      "destination": "/veritas/index.html"
    },
    {
      "source": "/veritas",
      "destination": "/veritas/index.html"
    }
  ]
}
