{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "builds": [
    { "src": "*.html", "use": "@vercel/static" },
    { "src": "*.js", "use": "@vercel/static" },
    { "src": "*.css", "use": "@vercel/static" },
    { "src": "*.json", "use": "@vercel/static" },
    { "src": "*.svg", "use": "@vercel/static" },
    { "src": "*.png", "use": "@vercel/static" },
    { "src": "*.ico", "use": "@vercel/static" },
    { "src": "*.pdf", "use": "@vercel/static" },
    { "src": "*.txt", "use": "@vercel/static" },
    { "src": "*.xml", "use": "@vercel/static" },
    { "src": "assets/**/*", "use": "@vercel/static" },
    { "src": "branding/**/*", "use": "@vercel/static" },
    { "src": "blog/**/*", "use": "@vercel/static" },
    { "src": "case-studies/**/*", "use": "@vercel/static" },
    { "src": "admin/**/*", "use": "@vercel/static" },
    { "src": "hardened-suite/**/*", "use": "@vercel/static" },
    { "src": "practice-areas/**/*", "use": "@vercel/static" },
    { "src": "resources/**/*", "use": "@vercel/static" },
    { "src": "veritas/**/*", "use": "@vercel/static" },
    { "src": "desktop/**/*", "use": "@vercel/static" }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://web-production-aeb0b0.up.railway.app/api/$1" },
    { "source": "/meritscan/(.*)", "destination": "https://web-production-aeb0b0.up.railway.app/meritscan/$1" },
    { "source": "/chat/(.*)", "destination": "https://web-production-aeb0b0.up.railway.app/chat/$1" },
    { "source": "/veritas/upload", "destination": "https://web-production-aeb0b0.up.railway.app/veritas/upload" },
    { "source": "/veritas/:path*", "destination": "/veritas/index.html" },
    { "source": "/admin/:path*", "destination": "/admin/index.html" },
    { "source": "/hardened-suite/:path*", "destination": "/hardened-suite/index.html" },
    { "source": "/practice-areas/:path*", "destination": "/practice-areas/index.html" },
    { "source": "/desktop/:path*", "destination": "/desktop/index.html" },
    { "source": "/signin", "destination": "/signin.html" },
    { "source": "/blog/articles.json", "destination": "/blog/articles.json" },
    { "source": "/blog/([^/.]+)", "destination": "/blog/$1.html" },
    { "source": "/case-studies/([^/.]+)", "destination": "/case-studies/$1.html" },
    { "source": "/practice-areas/medical-malpractice/([^/.]+)", "destination": "/practice-areas/medical-malpractice/$1.html" }
  ]
}
