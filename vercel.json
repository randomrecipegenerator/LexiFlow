{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "memory": 512,
        "maxDuration": 30
      }
    },
    {
      "src": "*.html",
      "use": "@vercel/static"
    },
    {
      "src": "assets/**/*",
      "use": "@vercel/static"
    },
    {
      "src": "branding/**/*",
      "use": "@vercel/static"
    },
    {
      "src": "blog/**/*",
      "use": "@vercel/static"
    },
    {
      "src": "case-studies/**/*",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    {
      "source": "/veritas/:path*",
      "destination": "/veritas/index.html"
    },
    {
      "source": "/__engine/events",
      "destination": "/api/index.py"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/blog/articles.json",
      "destination": "/blog/articles.json"
    },
    {
      "source": "/blog/([^/.]+)",
      "destination": "/blog/$1.html"
    },
    {
      "source": "/case-studies/([^/.]+)",
      "destination": "/case-studies/$1.html"
    }
  ]
}
